{
  "name": "adedas-backend",
  "version": "1.0.0",
  "description": "Backend API for ADEDAS Multibusiness",
  "main": "dist/server.js",
  "type": "module",

  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:dev": "tsx src/server.ts",
